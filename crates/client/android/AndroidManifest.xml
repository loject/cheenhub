<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name="dev.dioxus.main.CheenHubApplication"
        android:allowNativeHeapPointerTagging="false"
        android:extractNativeLibs="true"
        android:hasCode="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <!--
            Эти публичные параметры Firebase нужно заменить значениями Android app из Firebase
            при сборке окружения. Service account и другие серверные секреты сюда не добавляются.
        -->
        <meta-data
            android:name="ru.cheenhub.firebase.project_id"
            android:value="CONFIGURE_CHEENHUB_FIREBASE_PROJECT_ID" />
        <meta-data
            android:name="ru.cheenhub.firebase.application_id"
            android:value="CONFIGURE_CHEENHUB_FIREBASE_APPLICATION_ID" />
        <meta-data
            android:name="ru.cheenhub.firebase.api_key"
            android:value="CONFIGURE_CHEENHUB_FIREBASE_API_KEY" />
        <meta-data
            android:name="ru.cheenhub.firebase.sender_id"
            android:value="CONFIGURE_CHEENHUB_FIREBASE_SENDER_ID" />

        <activity
            android:name="dev.dioxus.main.MainActivity"
            android:configChanges="orientation|screenLayout|screenSize|keyboardHidden"
            android:exported="true"
            android:label="@string/app_name">
            <meta-data android:name="android.app.lib_name" android:value="main" />
            <meta-data android:name="android.app.func_name" android:value="ANativeActivity_onCreate" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="dev.dioxus.main.DioxusForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|mediaPlayback|camera|mediaProjection" />

        <service
            android:name="dev.dioxus.main.CheenHubFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
