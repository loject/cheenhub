        "panel": "dedicated",
        "group": "cheenhub-dev",
        "clear": true
      },
      "problemMatcher": {
        "base": "$rustc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      }
    },
