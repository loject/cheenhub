    {
      "label": "CheenHub: create git tag",
      "type": "shell",
      "command": "cargo",
      "args": [
        "make",
        "create-git-tag",
        "${input:cheenhubGitTag}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "group": "cheenhub-release",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "cheenhubGitTag",
      "type": "promptString",
      "description": "Git tag name, for example v1.0.0"
    }
  ]
