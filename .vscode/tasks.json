{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CheenHub: bootstrap cargo-make",
      "type": "shell",
      "command": "cargo",
      "args": [
        "install",
        "--locked",
        "cargo-make"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "group": "cheenhub-dev",
        "clear": true,
        "close": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "CheenHub: setup dev tools",
      "type": "shell",
      "command": "cargo",
      "args": [
        "make",
        "setup"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "group": "cheenhub-dev",
        "clear": true,
        "close": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "CheenHub: dev stack",
      "type": "shell",
      "command": "cargo",
      "args": [
        "make",
        "dev-stack"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "group": "cheenhub-dev",
        "clear": true
      },
      "problemMatcher": {
        "base": "$rustc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      }
    },
    {
      "label": "CheenHub: dev services",
      "type": "shell",
      "command": "cargo",
      "args": [
        "make",
        "dev-services"
      ],
