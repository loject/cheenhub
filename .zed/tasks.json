[
  {
    "label": "CheenHub: bootstrap cargo-make",
    "command": "cargo",
    "args": [
      "install",
      "--locked",
      "cargo-make"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: setup dev tools",
    "command": "cargo",
    "args": [
      "make",
      "setup"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: dev stack",
    "command": "cargo",
    "args": [
      "make",
      "dev-stack"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: dev services",
    "command": "cargo",
    "args": [
      "make",
      "dev-services"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: ensure Docker Desktop",
    "command": "cargo",
    "args": [
      "make",
      "ensure-docker-desktop"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: ensure Postgres",
    "command": "cargo",
    "args": [
      "make",
      "ensure-postgres"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: dioxus web",
    "command": "cargo",
    "args": [
      "make",
      "dioxus-web"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: backend watch",
    "command": "cargo",
    "args": [
      "make",
      "backend-watch"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: migrate database",
    "command": "cargo",
    "args": [
      "make",
      "migrate-database"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "CheenHub: create git tag",
    "command": "printf 'Git tag name: '; read -r tag; if [ -z \"$tag\" ]; then echo 'Tag name is required.' >&2; exit 1; fi; if git rev-parse -q --verify \"refs/tags/$tag\" >/dev/null; then echo \"Tag already exists: $tag\" >&2; exit 1; fi; git tag \"$tag\" && echo \"Created git tag: $tag\"",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  }
]
