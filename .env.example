CHEENHUB_DOMAIN=cheenhub.ru
CHEENHUB_BACKEND_IMAGE_REF=ghcr.io/loject/cheenhub/backend:v0.1.0
CHEENHUB_WEB_IMAGE_REF=ghcr.io/loject/cheenhub/web:v0.1.0

POSTGRES_DB=cheenhub
POSTGRES_USER=cheenhub
# Сгенерируйте надежный пароль (например, `openssl rand -hex 32`).
# Для прод-окружения используйте deploy/scripts/prepare-production-env.sh.
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_SECRET

DATABASE_URL=postgres://cheenhub:REPLACE_WITH_STRONG_SECRET@db:5432/cheenhub
AUTH_STORE=postgres
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
RUST_LOG=cheenhub_backend=info,tower_http=info,warn

JWT_ED25519_PRIVATE_KEY_BASE64=base64-encoded-32-byte-ed25519-seed
JWT_KEY_ID=prod-ed25519-1
CHEENHUB_JWT_KEY_ID=prod-ed25519-1
CHEENHUB_JWT_PUBLIC_KEY_BASE64=base64-encoded-32-byte-ed25519-public-key
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=30

CHEENHUB_CLIENT_BASE_URL=https://cheenhub.ru
CHEENHUB_API_BASE_URL=https://cheenhub.ru/api
CHEENHUB_REALTIME_URL=https://cheenhub.ru/realtime
CHEENHUB_REALTIME_CERT_SHA256=

WEBTRANSPORT_HOST=0.0.0.0
WEBTRANSPORT_PORT=4443
WEBTRANSPORT_TLS_CERT_PATH=/etc/letsencrypt/live/cheenhub.ru/fullchain.pem
WEBTRANSPORT_TLS_KEY_PATH=/etc/letsencrypt/live/cheenhub.ru/privkey.pem

OAUTH_STATE_LIFETIME_MINUTES=10
OAUTH_HANDOFF_LIFETIME_MINUTES=5
OAUTH_REGISTRATION_LIFETIME_MINUTES=15
PASSWORD_RESET_TOKEN_LIFETIME_MINUTES=30
SMTP_PORT=587

CHAT_IMAGES_S3_ENDPOINT=https://s3.cloud.ru
CHAT_IMAGES_S3_REGION=ru-central-1
CHAT_IMAGES_S3_BUCKET=cheenhub-chat-images
CHAT_IMAGES_S3_ACCESS_KEY_ID=tenant_id:key_id
CHAT_IMAGES_S3_SECRET_ACCESS_KEY=key_secret
CHAT_IMAGES_S3_FORCE_PATH_STYLE=true
