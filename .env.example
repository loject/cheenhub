# Локальная конфигурация разработки. Ее можно скопировать в .env.
# Production env создается через deploy/scripts/prepare-production-env.sh.

POSTGRES_DB=cheenhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_PORT=5432

DATABASE_URL=postgres://postgres:mysecretpassword@127.0.0.1:5432/cheenhub
AUTH_STORE=postgres
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
RUST_LOG=cheenhub_backend=debug,tower_http=debug,info

# Dev-only JWT key pair. Для production обязательно сгенерировать новую пару.
JWT_ED25519_PRIVATE_KEY_BASE64=mDCApL9bgU9S0xvhayOzkyBirRsYZ8xynp0j4Jl0ba8=
JWT_KEY_ID=dev-ed25519-1
CHEENHUB_JWT_KEY_ID=dev-ed25519-1
CHEENHUB_JWT_PUBLIC_KEY_BASE64=IPjpecEo7+UeN7Hjq6WO44rzLYLOzf3gZ+QSj55bkWo=
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=30

CHEENHUB_CLIENT_BASE_URL=http://127.0.0.1:8080
CHEENHUB_API_BASE_URL=http://127.0.0.1:3000/api
CHEENHUB_REALTIME_URL=https://127.0.0.1:4443/realtime

WEBTRANSPORT_HOST=127.0.0.1
WEBTRANSPORT_PORT=4443
WEBTRANSPORT_TLS_CERT_PATH=target/cheenhub-dev/webtransport-cert.pem
WEBTRANSPORT_TLS_KEY_PATH=target/cheenhub-dev/webtransport-key.pem

OAUTH_STATE_LIFETIME_MINUTES=10
OAUTH_HANDOFF_LIFETIME_MINUTES=5
OAUTH_REGISTRATION_LIFETIME_MINUTES=15
PASSWORD_RESET_TOKEN_LIFETIME_MINUTES=30
SMTP_PORT=587

# Для локальной разработки S3 выключен. Раскомментируй все поля вместе,
# если нужно проверить загрузку изображений через S3-совместимое хранилище.
# CHAT_IMAGES_S3_ENDPOINT=https://s3.example.local
# CHAT_IMAGES_S3_REGION=local
# CHAT_IMAGES_S3_BUCKET=cheenhub-chat-images
# CHAT_IMAGES_S3_ACCESS_KEY_ID=tenant_id:key_id
# CHAT_IMAGES_S3_SECRET_ACCESS_KEY=key_secret
# CHAT_IMAGES_S3_FORCE_PATH_STYLE=true
